<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/commentsLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:descendantFocusability="afterDescendants"
    android:fillViewport="true"
    android:focusable="false"
    android:nextFocusUp="@+id/mediaNavPills">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/commentsRefresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:focusable="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/commentsLogo"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:adjustViewBounds="true"
                android:scaleType="fitStart"
                android:visibility="gone"
                tools:ignore="ContentDescription"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/commentsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <Button
                android:id="@+id/commentsAddToList"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:ellipsize="marquee"
                android:fontFamily="@font/poppins_bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:nextFocusDown="@+id/commentSourceSanin"
                android:text="@string/add_list"
                android:textAllCaps="false"
                android:textColor="?attr/colorOnBackground"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/commentSourceBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/commentSourceSanin"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_transparent_round"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:nextFocusRight="@+id/commentSourceTrakt"
                    android:nextFocusDown="@+id/commentMessageContainer"
                    android:text="Sanin"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnBackground" />

                <TextView
                    android:id="@+id/commentSourceTrakt"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_transparent_round"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:nextFocusLeft="@+id/commentSourceSanin"
                    android:nextFocusDown="@+id/commentMessageContainer"
                    android:text="Trakt"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnBackground" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/commentMessageContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:focusable="true"
                android:nextFocusDown="@+id/commentCurrentProgress"
                android:nextFocusUp="@+id/commentSourceTrakt"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/commentReplyToContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:ignore="UseCompoundDrawables">

                    <TextView
                        android:id="@+id/commentReplyTo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:singleLine="true"
                        android:text="Replying to "
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        tools:ignore="HardcodedText" />

                    <ImageView
                        android:id="@+id/commentReplyToCancel"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="16dp"
                        android:background="?android:attr/selectableItemBackground"
                        app:srcCompat="@drawable/ic_round_close_24"
                        app:tint="@android:color/white"
                        tools:ignore="ContentDescription" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/commentInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/commentUserAvatar"
                        style="@style/CircularImageView"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:scaleType="center"
                        app:srcCompat="@drawable/ic_round_add_circle_24"
                        tools:ignore="ContentDescription,ImageContrastCheck" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/bg_black"
                        app:cardCornerRadius="8dp"
                        app:strokeColor="?attr/colorPrimaryContainer"
                        app:strokeWidth="2dp">

                        <EditText
                            android:id="@+id/commentInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="The One Piece is real"
                            android:background="@null"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:hint="Add a comment..."
                            android:inputType="textMultiLine"
                            android:maxLength="300"
                            android:maxLines="8"
                            android:paddingStart="8dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="36dp"
                            android:paddingBottom="8dp"
                            android:textSize="12sp"
                            android:textColor="@android:color/white"
                            tools:ignore="HardcodedText" />
                    </com.google.android.material.card.MaterialCardView>

                    <ImageButton
                        android:id="@+id/commentGif"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="4dp"
                        android:alpha="0.5"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:padding="2dp"
                        android:src="@drawable/ic_round_gif_24"
                        android:visibility="gone"
                        app:tint="@android:color/white"
                        tools:ignore="ContentDescription"
                        tools:visibility="visible" />

                    <ImageButton
                        android:id="@+id/commentSpoiler"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:layout_marginEnd="8dp"
                        android:alpha="0.5"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_round_remove_red_eye_24"
                        android:visibility="gone"
                        app:tint="@android:color/white"
                        tools:ignore="ContentDescription"
                        tools:visibility="visible" />

                    <ImageButton
                        android:id="@+id/commentLabel"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/ic_label_off_24"
                        android:visibility="gone"
                        tools:ignore="ContentDescription"
                        tools:visibility="visible" />

                    <ImageButton
                        android:id="@+id/commentSend"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/ic_round_send_24"
                        android:visibility="gone"
                        tools:ignore="ContentDescription"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical|end"
                android:orientation="horizontal"
                tools:ignore="UseCompoundDrawables">

                <TextView
                    android:id="@+id/commentCurrentProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.6"
                    android:background="@drawable/btn_transparent_round"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="3dp"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="12sp"
                    android:nextFocusUp="@+id/commentMessageContainer"
                    android:nextFocusDown="@+id/commentsList"
                    android:nextFocusRight="@+id/openRules"
                    android:visibility="gone"
                    tools:text="Ep 12"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/openRules"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="12dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:contentDescription="@string/open_rules"
                    android:focusable="true"
                    android:nextFocusUp="@+id/commentMessageContainer"
                    android:nextFocusDown="@+id/commentsList"
                    android:nextFocusLeft="@+id/commentCurrentProgress"
                    android:nextFocusRight="@+id/commentFilter"
                    app:srcCompat="@drawable/ic_round_info_24"
                    app:tint="?attr/colorOnBackground" />

                <ImageView
                    android:id="@+id/commentFilter"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="12dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:contentDescription="@string/sort_by"
                    android:focusable="true"
                    android:nextFocusUp="@+id/commentMessageContainer"
                    android:nextFocusDown="@+id/commentsList"
                    android:nextFocusLeft="@+id/openRules"
                    android:nextFocusRight="@+id/commentSort"
                    app:srcCompat="@drawable/ic_round_filter_alt_24"
                    app:tint="?attr/colorOnBackground" />

                <ImageView
                    android:id="@+id/commentSort"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="12dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:contentDescription="@string/sort_by"
                    android:focusable="true"
                    android:nextFocusUp="@+id/commentMessageContainer"
                    android:nextFocusDown="@+id/commentsList"
                    android:nextFocusLeft="@+id/commentFilter"
                    app:srcCompat="@drawable/ic_round_sort_24"
                    app:tint="?attr/colorOnBackground" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/commentsProgressBar"
                android:layout_width="76.5dp"
                android:layout_height="76.5dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginTop="64dp"
                tools:visibility="gone"
            >

                <com.airbnb.lottie.LottieAnimationView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="4dp"
                app:lottie_rawRes="@raw/tomoe"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_colorFilter="?attr/colorSecondary" 
                app:lottie_speed="1.75" android:rotation="75" />

                <com.airbnb.lottie.LottieAnimationView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                app:lottie_rawRes="@raw/tomoe"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_colorFilter="?attr/colorSecondary" 
                app:lottie_speed="1.75" android:rotation="-45" />

                <com.airbnb.lottie.LottieAnimationView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="8dp"
                app:lottie_rawRes="@raw/tomoe"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_colorFilter="?attr/colorSecondary" 
                app:lottie_speed="1.75" android:rotation="195" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/commentsListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/commentsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:nestedScrollingEnabled="true"
                    android:nextFocusUp="@+id/commentSort"
                    android:visibility="gone"
                    tools:listitem="@layout/item_comments"
                    tools:visibility="visible" />

                <FrameLayout
                    android:id="@+id/commentBottomRefresh"
                    android:layout_width="76.5dp"
                    android:layout_height="76.5dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="32dp"
                    android:visibility="gone"
                >

                    <com.airbnb.lottie.LottieAnimationView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="center_horizontal|top"
                    android:layout_marginTop="4dp"
                    app:lottie_rawRes="@raw/tomoe"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_colorFilter="?attr/colorSecondary" 
                    app:lottie_speed="1.75" android:rotation="75" />

                    <com.airbnb.lottie.LottieAnimationView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="8dp"
                    app:lottie_rawRes="@raw/tomoe"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_colorFilter="?attr/colorSecondary" 
                    app:lottie_speed="1.75" android:rotation="-45" />

                    <com.airbnb.lottie.LottieAnimationView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="8dp"
                    app:lottie_rawRes="@raw/tomoe"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_colorFilter="?attr/colorSecondary" 
                    app:lottie_speed="1.75" android:rotation="195" />

                </FrameLayout>
            </FrameLayout>
            <TextView
                android:id="@+id/commentsOfflineText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="64dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="You need to have an internet connection to use comments"
                android:textColor="?attr/colorOnBackground"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.core.widget.NestedScrollView>