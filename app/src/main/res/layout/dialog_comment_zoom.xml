<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="48dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/zoomUserAvatar"
                    style="@style/CircularImageView"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:nextFocusDown="@+id/zoomReply"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/ic_round_add_circle_24" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/zoomUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/zoomUserTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.6"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/zoomClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:focusable="true"
                    android:nextFocusDown="@+id/zoomUserAvatar"
                    android:padding="4dp"
                    android:src="@drawable/ic_round_close_24"
                    app:tint="?attr/colorOnBackground" />
            </LinearLayout>

            <TextView
                android:id="@+id/zoomCommentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground"
                android:lineSpacingExtra="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/zoomVotes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:textSize="12sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/zoomTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/zoomReply"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusUp="@+id/zoomUserAvatar"
                    android:nextFocusLeft="@+id/zoomUserAvatar"
                    android:nextFocusRight="@+id/zoomUpVote"
                    android:padding="8dp"
                    android:src="@drawable/ic_round_reply_24"
                    app:tint="?attr/colorOnBackground"
                    tools:ignore="ContentDescription" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/zoomUpVote"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/zoomReply"
                    android:nextFocusRight="@+id/zoomVoteCount"
                    android:nextFocusUp="@+id/zoomUserAvatar"
                    android:padding="8dp"
                    android:src="@drawable/ic_round_upvote_inactive_24"
                    app:tint="?attr/colorOnBackground"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/zoomVoteCount"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:alpha="0.8"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:gravity="center"
                    android:minWidth="32dp"
                    android:nextFocusLeft="@+id/zoomUpVote"
                    android:nextFocusRight="@+id/zoomDownVote"
                    android:nextFocusUp="@+id/zoomUserAvatar"
                    android:text="0"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnBackground" />

                <ImageView
                    android:id="@+id/zoomDownVote"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusLeft="@+id/zoomVoteCount"
                    android:nextFocusUp="@+id/zoomUserAvatar"
                    android:padding="8dp"
                    android:rotation="270"
                    android:src="@drawable/ic_round_upvote_inactive_24"
                    app:tint="?attr/colorOnBackground"
                    tools:ignore="ContentDescription" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
