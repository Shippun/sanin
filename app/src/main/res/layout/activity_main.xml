<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainDrawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/mainProgressBar"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_gravity="center"
        >

            <com.airbnb.lottie.LottieAnimationView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="4dp"
            app:lottie_rawRes="@raw/tomoe"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_colorFilter="?attr/colorSecondary" 
            app:lottie_speed="1.75"
        android:rotation="0" />

            <com.airbnb.lottie.LottieAnimationView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp"
            app:lottie_rawRes="@raw/tomoe"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_colorFilter="?attr/colorSecondary" 
            app:lottie_speed="1.75"
        android:rotation="120" />

            <com.airbnb.lottie.LottieAnimationView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            app:lottie_rawRes="@raw/tomoe"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_colorFilter="?attr/colorSecondary" 
            app:lottie_speed="1.75"
        android:rotation="240" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:fitsSystemWindows="true"
            android:gravity="end"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/mainAvatarContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mainCalendarContainer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/nav_bg_inv"
                    android:focusable="true"
                    android:nextFocusDown="@id/homeBannerCarousel"
                    app:cardCornerRadius="22dp">

                    <androidx.constraintlayout.utils.widget.ImageFilterView
                        android:id="@+id/mainCalendarIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_round_calendar_today_24"
                        app:tint="@color/bg_white"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mainUserAvatarContainer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="52dp"
                    android:backgroundTint="@color/nav_bg_inv"
                    android:focusable="true"
                    android:nextFocusDown="@id/homeBannerCarousel"
                    app:cardCornerRadius="22dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/mainUserAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:scaleType="centerCrop"
                        tools:ignore="ContentDescription" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/mainNotificationCount"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="end|bottom"
                    android:background="@drawable/notification_circle"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:gravity="center"
                    android:textColor="#F3F3F3"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:translationX="-28dp"
                    tools:ignore="SmallSp"
                    tools:text="1"
                    tools:visibility="visible" />
            </FrameLayout>
        </LinearLayout>

    <FrameLayout
        android:id="@+id/homeNavRail"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="8dp"
        android:elevation="10dp"
        android:translationZ="10dp"
        android:focusable="true"
        android:descendantFocusability="afterDescendants"
        android:visibility="gone"
        android:clipToOutline="true">

        <ani.dantotsu.ui.components.SnakeNavRailView
            android:id="@+id/homeNavRailBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:focusable="false"
            android:clickable="false"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

                <ImageButton
                    android:id="@+id/homeNavHome"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_round_home_24"
                    android:scaleType="fitCenter"
                    android:background="@android:color/transparent"
                    android:focusable="true"
                    android:nextFocusUp="@id/homeNavLibrary"
                    android:nextFocusDown="@id/homeNavAnime" />

                <ImageButton
                    android:id="@+id/homeNavAnime"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_round_movie_filter_24"
                    android:scaleType="fitCenter"
                    android:background="@android:color/transparent"
                    android:focusable="true"
                    android:nextFocusUp="@id/homeNavHome"
                    android:nextFocusDown="@id/homeNavDiscovery" />

                <ImageButton
                    android:id="@+id/homeNavDiscovery"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_round_filter_list_24"
                    android:scaleType="fitCenter"
                    android:background="@android:color/transparent"
                    android:focusable="true"
                    android:nextFocusUp="@id/homeNavAnime"
                    android:nextFocusDown="@id/homeNavLibrary" />

                <ImageButton
                    android:id="@+id/homeNavLibrary"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_round_library_books_24"
                    android:scaleType="fitCenter"
                    android:background="@android:color/transparent"
                    android:focusable="true"
                    android:nextFocusUp="@id/homeNavDiscovery"
                    android:nextFocusDown="@id/homeNavHome" />
            </LinearLayout>
        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/incognito"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="start|top"
            android:layout_margin="16dp"
            android:translationZ="7dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_opp"
            app:cardCornerRadius="16dp">

            <androidx.constraintlayout.utils.widget.ImageFilterView
                android:id="@+id/incognitoImage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_incognito_24"
                app:tint="@color/bg"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/rescueModeIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="start|top"
            android:layout_margin="16dp"
            android:translationZ="7dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardCornerRadius="16dp">

            <androidx.constraintlayout.utils.widget.ImageFilterView
                android:id="@+id/rescueModeImage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_myanimelist"
                app:tint="?attr/colorOnPrimaryContainer"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <include layout="@layout/drawer_right_rail" />
</androidx.drawerlayout.widget.DrawerLayout>
