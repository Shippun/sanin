<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:descendantFocusability="afterDescendants"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".settings.SettingsAnimationActivity"
    tools:ignore="SpeakableTextPresentCheck">

    <LinearLayout
        android:id="@+id/animationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/nav_bg_inv"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <ImageButton
                    android:id="@+id/animationBack"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@color/nav_bg_inv"
                    android:focusable="true"
                    android:padding="16dp"
                    app:srcCompat="@drawable/ic_round_arrow_back_ios_new_24"
                    app:tint="?attr/colorOnBackground"
                    tools:ignore="ContentDescription" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="32dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_bold"
                    android:text="@string/animation"
                    android:textSize="28sp" />

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="20dp"
                    android:padding="24dp"
                    app:srcCompat="@drawable/ic_round_animation_24"
                    app:tint="?attr/colorOnBackground"
                    tools:ignore="ContentDescription" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="64dp"
            android:clipToPadding="false"
            android:orientation="vertical">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/animationEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:drawableStart="@drawable/ic_round_animation_24"
                android:drawablePadding="16dp"
                android:elegantTextHeight="true"
                android:focusable="true"
                android:fontFamily="@font/poppins_bold"
                android:minHeight="64dp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Animations"
                android:textAlignment="viewStart"
                android:textColor="?attr/colorOnBackground"
                app:cornerRadius="0dp"
                app:drawableTint="?attr/colorPrimary"
                app:showText="false"
                app:thumbTint="@color/button_switch_track" />

            <TextView
                android:id="@+id/animationSectionDisplay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:drawablePadding="16dp"
                android:focusable="true"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center_vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Display Animations"
                android:textColor="?attr/colorOnBackground"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_round_keyboard_arrow_down_24"
                app:drawableTint="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/animationSectionDisplayContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_photo_size_select_actual_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="@string/banner_animations"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_animation_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="@string/layout_animations"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationTrending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/trail_length_short"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="@string/trending_scroller"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />
            </LinearLayout>

            <TextView
                android:id="@+id/animationSectionNavigation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:drawablePadding="16dp"
                android:focusable="true"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center_vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Navigation Animations"
                android:textColor="?attr/colorOnBackground"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_round_keyboard_arrow_down_24"
                app:drawableTint="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/animationSectionNavigationContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationLiveSideRail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_animation_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Live Side Rail"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_person_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Profile Animations"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_home_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Home Page Animations"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationNavRail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_area_chart_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Nav Rail Animations"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />
            </LinearLayout>

            <TextView
                android:id="@+id/animationSectionPlayer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:drawablePadding="16dp"
                android:focusable="true"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center_vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Player Animations"
                android:textColor="?attr/colorOnBackground"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_round_keyboard_arrow_down_24"
                app:drawableTint="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/animationSectionPlayerContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationPlayerGesture"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_touch_app_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Gesture Animations"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationPlayerController"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_play_circle_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Controller Animations"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationPlayerOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_pause_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Pause Overlay"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationDoubleTap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_fast_forward_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Double-Tap FF/RW"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_filter_list_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Seek Bar Focus"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationProgressShake"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_audiotrack_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Progress Shake"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />
            </LinearLayout>

            <TextView
                android:id="@+id/animationSectionFocus"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:drawablePadding="16dp"
                android:focusable="true"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center_vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Focus &amp; Keyboard"
                android:textColor="?attr/colorOnBackground"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_round_keyboard_arrow_down_24"
                app:drawableTint="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/animationSectionFocusContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationFocusEffects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_equal_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Focus Effects"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationKeyboardKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_keyboard_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Keyboard Key Press"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />
            </LinearLayout>

            <TextView
                android:id="@+id/animationSectionDialogs"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:drawablePadding="16dp"
                android:focusable="true"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center_vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Dialogs &amp; Transitions"
                android:textColor="?attr/colorOnBackground"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_round_keyboard_arrow_down_24"
                app:drawableTint="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/animationSectionDialogsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationTransitions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_sync_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Tab &amp; Dialog Transitions"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationNotificationPopup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_notifications_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Notification Popup"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationCommentInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_edit_note_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Comment Input"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationImageDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_image_search_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Image Dialog"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />
            </LinearLayout>

            <TextView
                android:id="@+id/animationSectionOther"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:drawablePadding="16dp"
                android:focusable="true"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center_vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="Other UI"
                android:textColor="?attr/colorOnBackground"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_round_keyboard_arrow_down_24"
                app:drawableTint="?attr/colorPrimary" />

            <LinearLayout
                android:id="@+id/animationSectionOtherContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationSplash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_brightness_4_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Splash Fade"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
                    app:drawableTint="?attr/colorPrimary"
                    app:showText="false"
                    app:thumbTint="@color/button_switch_track" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/animationLikeButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:drawableStart="@drawable/ic_round_favorite_24"
                    android:drawablePadding="16dp"
                    android:elegantTextHeight="true"
                    android:focusable="true"
                    android:fontFamily="@font/poppins_bold"
                    android:minHeight="64dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:text="Like Button"
                    android:textAlignment="viewStart"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="0dp"
