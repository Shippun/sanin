<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/top_sheet_background"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingLeft="16dp"
    android:paddingRight="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:weightSum="10">

            <TextView android:id="@+id/keyQ" android:text="Q" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyW" android:text="W" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyE" android:text="E" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyR" android:text="R" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyT" android:text="T" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyY" android:text="Y" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyU" android:text="U" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyI" android:text="I" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyO" android:text="O" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyP" android:text="P" style="@style/TvKeyboardKey" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:weightSum="10">

            <TextView android:id="@+id/keyA" android:text="A" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyS" android:text="S" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyD" android:text="D" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyF" android:text="F" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyG" android:text="G" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyH" android:text="H" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyJ" android:text="J" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyK" android:text="K" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyL" android:text="L" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyBackspace" android:text="⌫" style="@style/TvKeyboardKey" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:weightSum="10">

            <TextView android:id="@+id/keyZ" android:text="Z" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyX" android:text="X" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyC" android:text="C" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyV" android:text="V" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyB" android:text="B" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyN" android:text="N" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyM" android:text="M" style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyComma" android:text="," style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyPeriod" android:text="." style="@style/TvKeyboardKey" />
            <TextView android:id="@+id/keyEnter" android:text="↵" style="@style/TvKeyboardKey" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView android:id="@+id/keyModeToggle" android:text="123" style="@style/TvKeyboardKey"
                android:layout_width="0dp" android:layout_weight="1.5" />
            <TextView android:id="@+id/keySpace" android:text="Space" style="@style/TvKeyboardKey"
                android:layout_width="0dp" android:layout_weight="3" />
            <TextView android:id="@+id/keyHide" android:text="Hide" style="@style/TvKeyboardKeyDanger"
                android:layout_width="0dp" android:layout_weight="1" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
