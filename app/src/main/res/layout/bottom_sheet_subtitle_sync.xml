<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/syncRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_background"
    android:orientation="horizontal"
    android:padding="8dp">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="400dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/noSubtitlesNotice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0.7"
            android:text="No subtitles loaded"
            android:textSize="18sp"
            android:textStyle="italic"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/subtitleSyncRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="4dp"
            tools:listitem="@layout/item_subtitle_sync" />
    </FrameLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="12dp"
        android:background="#33FFFFFF" />

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/syncTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/poppins_semi_bold"
            android:gravity="center"
            android:text="Subtitle Sync"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/syncStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            tools:text="Offset: 0ms - In sync" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/syncSubtractMore"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:gravity="center"
                android:text="-1s"
                android:textSize="14sp" />

            <Button
                android:id="@+id/syncSubtract"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:focusable="true"
                android:gravity="center"
                android:text="-100ms"
                android:textSize="12sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/syncOffsetInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginVertical="8dp"
            android:autofillHints="no"
            android:focusable="true"
            android:gravity="center"
            android:hint="ms"
            android:inputType="numberSigned"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/syncAdd"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:gravity="center"
                android:text="+100ms"
                android:textSize="12sp" />

            <Button
                android:id="@+id/syncAddMore"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:focusable="true"
                android:gravity="center"
                android:text="+1s"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/syncCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:text="Cancel"
                android:textSize="12sp" />

            <Button
                android:id="@+id/syncReset"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:focusable="true"
                android:text="Reset"
                android:textSize="12sp" />

            <Button
                android:id="@+id/syncApply"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:focusable="true"
                android:text="Apply"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
