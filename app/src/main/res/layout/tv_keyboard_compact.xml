<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/top_sheet_background"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start">

        <EditText
            android:id="@+id/keyPreview"
            android:layout_width="280dp"
            android:layout_height="32dp"
            android:background="@drawable/snake_input_bg"
            android:padding="4dp"
            android:textSize="14sp"
            android:singleLine="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:cursorVisible="true"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal">

            <TextView android:id="@+id/keyQ" android:text="Q" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyW" android:text="W" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyE" android:text="E" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyR" android:text="R" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyT" android:text="T" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyY" android:text="Y" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyU" android:text="U" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyI" android:text="I" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyO" android:text="O" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyP" android:text="P" style="@style/TvKeyboardKeyCompact" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal">

            <TextView android:id="@+id/keyA" android:text="A" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyS" android:text="S" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyD" android:text="D" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyF" android:text="F" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyG" android:text="G" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyH" android:text="H" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyJ" android:text="J" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyK" android:text="K" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyL" android:text="L" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyBackspace" android:text="⌫" style="@style/TvKeyboardKeyCompact" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal">

            <TextView android:id="@+id/keyZ" android:text="Z" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyX" android:text="X" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyC" android:text="C" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyV" android:text="V" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyB" android:text="B" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyN" android:text="N" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyM" android:text="M" style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyComma" android:text="," style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyPeriod" android:text="." style="@style/TvKeyboardKeyCompact" />
            <TextView android:id="@+id/keyEnter" android:text="↵" style="@style/TvKeyboardKeyCompact" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView android:id="@+id/keyModeToggle" android:text="123" style="@style/TvKeyboardKeyCompact"
                android:layout_width="40dp" />
            <TextView android:id="@+id/keySpace" android:text="Space" style="@style/TvKeyboardKeyCompact"
                android:layout_width="80dp" />
            <TextView android:id="@+id/keyHide" android:text="Hide" style="@style/TvKeyboardKeyDangerCompact"
                android:layout_width="40dp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
